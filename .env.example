# ─── Supabase ───────────────────────────────────────────────
# Copia este archivo a `.env.local` y rellena con los valores reales de tu
# proyecto Supabase (Project Settings → API).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# ─── Web Push (VAPID) ───────────────────────────────────────
# Clave pública VAPID para notificaciones push (genera el par con
# `npx web-push generate-vapid-keys`; la privada va en Supabase secrets).
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# ─── Tema por defecto ───────────────────────────────────────
# La app está fijada a la paleta oficial de marca: solo 'forest' está soportado.
VITE_DEFAULT_THEME=forest
